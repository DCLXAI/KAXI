// KAXI Prisma Schema
// Supabase/PostgreSQL is the only supported database target after Phase 0.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrgType {
  PLATFORM
  PARTNER_AGENT_OFFICE
}

enum UserRole {
  STUDENT
  PARTNER_AGENT
  PLATFORM_ADMIN
}

enum ConsentScope {
  TERMS
  PRIVACY
  THIRD_PARTY_PROVISION
  PROCESSING_CONSIGNMENT
  OVERSEAS_TRANSFER
  MARKETING
}

enum ConsentStatus {
  GRANTED
  WITHDRAWN
  EXPIRED
}

enum DocumentStatus {
  NOT_UPLOADED
  UPLOADED
  OCR_PROCESSING
  OCR_DONE
  MISSING
  EXPIRED
  NEEDS_REVIEW
  APPROVED
  REJECTED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_HUMAN_REVIEW
}

enum RuleStatus {
  DRAFT
  ACTIVE
  SUPERSEDED
  ARCHIVED
}

enum LegalReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EscalationStatus {
  NEW
  NEEDS_MORE_DOCUMENTS
  HIGH_RISK
  APPROVED
  REJECTED
  CLOSED
  STOPPED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  UNKNOWN
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  type      OrgType
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users               User[]
  escalationCases     EscalationCase[]
  partnerRequests     PartnerRequest[]
  partnerAgentInvites PartnerAgentInvite[]
  auditEvents         AuditEvent[]

  @@index([type])
  @@index([createdAt])
}

model User {
  id             String   @id @default(cuid())
  authUserId     String?  @unique @db.Uuid
  organizationId String?
  role           UserRole
  email          String?  @unique
  phone          String?  @unique
  zaloUid        String?  @unique
  locale         String   @default("vi")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization                  Organization?                  @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  studentProfile                StudentProfile?
  consents                      Consent[]
  uploadedFiles                 UploadedFile[]                 @relation("UploadedFileOwner")
  assignedCases                 EscalationCase[]               @relation("AssignedCases")
  assignedPartnerRequests       PartnerRequest[]               @relation("AssignedPartnerRequests")
  agentReviews                  AgentReview[]                  @relation("AgentReviewReviewer")
  documentVerificationFeedbacks DocumentVerificationFeedback[] @relation("DocumentVerificationFeedbackReviewer")
  caseTimelineEvents            CaseTimelineEvent[]            @relation("CaseTimelineActor")
  acceptedPartnerInvites        PartnerAgentInvite[]           @relation("AcceptedPartnerInvites")
  notifications                 UserNotification[]
  auditEvents                   AuditEvent[]                   @relation("AuditActor")
  diagnosisLeads                DiagnosisLead[]

  @@index([organizationId])
  @@index([role])
  @@index([createdAt])
}

model StudentProfile {
  id                    String    @id @default(cuid())
  userId                String    @unique
  nationality           String    @default("VN")
  visaType              String?
  targetVisa            String?
  chatStudyStage        String?
  visaExpiryDate        DateTime?
  alienRegistrationNo   String?
  alienRegistrationHash String?
  passportNo            String?
  passportHash          String?
  schoolName            String?
  programType           String?
  semesterStatus        String?
  topikLevel            Int?
  partTimePermitStatus  String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  journeyState          JourneyState?
  documents             DocumentItem[]
  complianceEvaluations ComplianceEvaluation[]
  escalationCases       EscalationCase[]

  @@index([nationality])
  @@index([visaType])
  @@index([visaExpiryDate])
  @@index([alienRegistrationHash])
  @@index([passportHash])
}

model Consent {
  id           String        @id @default(cuid())
  userId       String
  scope        ConsentScope
  status       ConsentStatus @default(GRANTED)
  version      String
  locale       String        @default("vi")
  grantedAt    DateTime      @default(now())
  withdrawnAt  DateTime?
  expiresAt    DateTime?
  evidenceJson Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([scope])
  @@index([status])
  @@index([grantedAt])
}

model PartnerAgentInvite {
  id             String    @id @default(cuid())
  organizationId String
  email          String?
  tokenHash      String    @unique
  status         String    @default("PENDING")
  expiresAt      DateTime
  acceptedAt     DateTime?
  acceptedUserId String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  acceptedUser User?        @relation("AcceptedPartnerInvites", fields: [acceptedUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([email])
  @@index([status])
  @@index([expiresAt])
  @@index([acceptedUserId])
}

model JourneyState {
  id               String   @id @default(cuid())
  studentProfileId String   @unique
  primaryStage     String
  modules          Json
  completionScore  Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
}

model DocumentItem {
  id                     String         @id @default(cuid())
  studentProfileId       String
  documentType           String
  required               Boolean        @default(true)
  status                 DocumentStatus @default(NOT_UPLOADED)
  expiresAt              DateTime?
  fileId                 String?
  reviewStatus           ReviewStatus   @default(PENDING)
  reviewNote             String?
  ocrExtractedCiphertext String?
  ocrExtractedRedacted   Json?
  ocrValidation          Json?
  ocrModel               String?
  ocrProcessedAt         DateTime?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  studentProfile        StudentProfile                 @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  file                  UploadedFile?                  @relation(fields: [fileId], references: [id], onDelete: SetNull)
  caseLinks             CaseDocumentLink[]
  verificationFeedbacks DocumentVerificationFeedback[]

  @@index([studentProfileId])
  @@index([documentType])
  @@index([status])
  @@index([reviewStatus])
  @@index([ocrProcessedAt])
  @@index([expiresAt])
}

model DocumentVerificationFeedback {
  id                   String   @id @default(cuid())
  documentItemId       String
  reviewerUserId       String?
  reviewerActor        String
  reviewerRole         String
  label                String
  issueCodes           Json
  layerStatuses        Json
  verificationSnapshot Json?
  note                 String?
  createdAt            DateTime @default(now())

  documentItem DocumentItem @relation(fields: [documentItemId], references: [id], onDelete: Cascade)
  reviewer     User?        @relation("DocumentVerificationFeedbackReviewer", fields: [reviewerUserId], references: [id], onDelete: SetNull)

  @@index([documentItemId])
  @@index([reviewerUserId])
  @@index([label])
  @@index([createdAt])
}

model VisaDocumentRequirement {
  id               String            @id @default(cuid())
  code             String            @unique
  visaType         String
  stayAction       String
  applicantContext String            @default("general")
  documentType     String
  labelKo          String
  labelEn          String
  required         Boolean           @default(true)
  validityDays     Int?
  issuer           String
  requiredFields   Json
  validationRules  Json
  sourceRefs       Json
  sourceUrl        String
  sourceType       String
  lastCheckedAt    DateTime
  checkedBy        String
  reviewStatus     LegalReviewStatus @default(PENDING)
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([visaType, stayAction, applicantContext, documentType])
  @@index([visaType])
  @@index([stayAction])
  @@index([documentType])
  @@index([issuer])
  @@index([reviewStatus])
  @@index([lastCheckedAt])
}

model UploadedFile {
  id           String    @id @default(cuid())
  ownerUserId  String
  storageKey   String    @unique
  originalName String
  mimeType     String
  sizeBytes    Int
  sha256       String
  piiClass     String
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?

  owner     User           @relation("UploadedFileOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  documents DocumentItem[]

  @@index([ownerUserId])
  @@index([sha256])
  @@index([piiClass])
  @@index([createdAt])
}

model DocumentFileBlob {
  id         String    @id @default(cuid())
  storageKey String    @unique
  mimeType   String
  sizeBytes  Int
  sha256     String
  bytes      Bytes
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  @@index([sha256])
  @@index([createdAt])
}

// 유학 경로 진단을 완료한 사용자 (리드)
model DiagnosisLead {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 기본 정보
  nickname    String
  nationality String // vn, mn, cn, uz, other
  age         Int
  education   String // highschool, college, university, master
  koreanLevel String // none, topik1, topik2, topik3
  goal        String // language, degree, transfer, career, unsure
  budget      Int // KRW
  region      String // seoul, gyeonggi, ...
  usingBroker Boolean @default(false)
  brokerCost  Int     @default(0)
  hasHistory  Boolean @default(false)

  // 진단 결과 (snapshot)
  pathKey         String // goal_language, goal_degree, ...
  estimatedCost   Int // KRW
  prepTime        String
  requiredDocs    String // JSON array of translation keys
  warningsJson    String // JSON array of {ko,vi,mn,en}
  nextActionsJson String // JSON array

  // 연락처 (선택)
  contact           String?
  contactType       String? // email, zalo, wechat, telegram
  contactCiphertext String?
  contactHash       String?
  contactRedacted   Boolean   @default(false)
  deleteRequestedAt DateTime?
  deletedAt         DateTime?
  retentionUntil    DateTime?

  // 상담 요청
  partnerRequests PartnerRequest[]

  // 계정 연결 (로그인 상태로 저장 시)
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([nationality])
  @@index([pathKey])
  @@index([contactHash])
  @@index([deleteRequestedAt])
  @@index([retentionUntil])
  @@index([userId])
  @@map("diagnosis_leads")
}

// 파트너 상담 요청
model PartnerRequest {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leadId String
  lead   DiagnosisLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  assignedUserId String?
  assignedUser   User?         @relation("AssignedPartnerRequests", fields: [assignedUserId], references: [id], onDelete: SetNull)

  partnerType        String // admin, translation, academy, admission, settlement
  question           String?
  questionCiphertext String?
  questionHash       String?
  questionRedacted   Boolean   @default(false)
  deleteRequestedAt  DateTime?
  deletedAt          DateTime?
  retentionUntil     DateTime?
  status             String    @default("pending") // pending, contacted, matched, accepted, closed
  matchedAt          DateTime?
  acceptedAt         DateTime?
  closedAt           DateTime?

  @@index([leadId])
  @@index([organizationId])
  @@index([assignedUserId])
  @@index([partnerType])
  @@index([status])
  @@index([matchedAt])
  @@index([questionHash])
  @@index([deleteRequestedAt])
  @@index([retentionUntil])
}

model UserNotification {
  id        String    @id @default(cuid())
  userId    String
  eventKey  String
  title     String
  message   String
  href      String?
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventKey])
  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, readAt])
  @@index([eventKey])
}

model HandoffLead {
  id                 String   @id
  sessionKey         String   @unique @map("session_id")
  tenantId           String   @default("default") @map("tenant_id")
  locale             String   @default("ko")
  source             String   @default("typebot")
  status             String   @default("contact_received")
  leadStage          String   @default("review") @map("lead_stage")
  riskLevel          String   @default("medium") @map("risk_level")
  name               String?
  nameCiphertext     String?  @map("name_ciphertext")
  nameRedacted       Boolean  @default(true) @map("name_redacted")
  question           String?
  questionCiphertext String?  @map("question_ciphertext")
  questionHash       String?  @map("question_hash")
  questionRedacted   Boolean  @default(false) @map("question_redacted")
  answer             String?
  answerCiphertext   String?  @map("answer_ciphertext")
  answerHash         String?  @map("answer_hash")
  answerRedacted     Boolean  @default(false) @map("answer_redacted")
  notes              String?
  notesCiphertext    String?  @map("notes_ciphertext")
  notesHash          String?  @map("notes_hash")
  notesRedacted      Boolean  @default(false) @map("notes_redacted")
  lastHandoffTaskId  BigInt?  @map("last_handoff_task_id")
  metadata           Json     @default("{}")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  contacts HandoffLeadContact[]

  @@index([tenantId, status, createdAt])
  @@index([source])
  @@index([leadStage, riskLevel])
  @@map("leads")
}

model HandoffLeadContact {
  id                String   @id
  leadId            String   @map("lead_id")
  sessionKey        String   @map("session_id")
  name              String?
  nameCiphertext    String?  @map("name_ciphertext")
  nameRedacted      Boolean  @default(true) @map("name_redacted")
  contactType       String   @default("unknown") @map("contact_type")
  contactValue      String?  @map("contact_value")
  contactCiphertext String?  @map("contact_ciphertext")
  contactHash       String   @map("contact_hash")
  contactRedacted   Boolean  @default(true) @map("contact_redacted")
  isPrimary         Boolean  @default(true) @map("is_primary")
  status            String   @default("received")
  metadata          Json     @default("{}")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  lead HandoffLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([leadId, contactHash])
  @@index([sessionKey])
  @@index([contactHash])
  @@index([status])
  @@map("lead_contacts")
}

// 학교 데이터 (수동 시드 — 운영시 관리자 페이지에서 편집)
// Operational source of truth for school data. src/lib/data/schools.ts is a local seed/fallback fixture only.
model School {
  id        String   @id
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nameKo String
  nameVi String
  nameMn String
  nameEn String

  region             String
  program            String
  tuitionPerSemester Int
  dormitoryAvailable Boolean  @default(false)
  dormitoryCost      Int?
  koreanRequirement  String
  accreditation      String // accredited, standard, caution
  topikLevel         Int?
  intake             String // JSON array
  officialUrl        String
  sourceUrl          String   @default("")
  verifiedAt         DateTime @default(now())
  reviewAfter        DateTime @default(now())
  notesKo            String
  notesVi            String
  notesMn            String
  notesEn            String

  @@index([region])
  @@index([program])
  @@index([accreditation])
  @@index([reviewAfter])
}

// AI 대화 로그 (RAG 검증/개선용)
model ChatLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  lang               String
  question           String
  questionCiphertext String?
  questionHash       String?
  questionRedacted   Boolean   @default(false)
  deleteRequestedAt  DateTime?
  deletedAt          DateTime?
  retentionUntil     DateTime?
  answer             String
  source             String // rule, rag, hybrid
  retrievedDocs      String? // JSON

  @@index([createdAt])
  @@index([lang])
  @@index([questionHash])
  @@index([deleteRequestedAt])
  @@index([retentionUntil])
}

model ChatSession {
  id                String    @id @default(cuid())
  sessionKey        String    @unique @map("session_key")
  tenantId          String    @default("default") @map("tenant_id")
  locale            String    @default("ko")
  source            String    @default("kaxi-site")
  channel           String    @default("kaxi-site")
  typebotResultId   String?   @unique @map("typebot_result_id")
  status            String    @default("active")
  startedAt         DateTime  @default(now()) @map("started_at")
  lastMessageAt     DateTime  @default(now()) @map("last_message_at")
  metadata          Json?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  endedAt           DateTime? @map("ended_at")
  retentionUntil    DateTime  @default(dbgenerated("now() + interval '90 days'")) @map("retention_until")
  deleteRequestedAt DateTime? @map("delete_requested_at")
  deletedAt         DateTime? @map("deleted_at")

  attachments     ChatAttachment[]
  handoffConsents HandoffConsentEvidence[]
  messages        ChatMessage[]
  retrievalRuns   RetrievalRun[]

  @@index([tenantId])
  @@index([locale])
  @@index([source])
  @@index([status])
  @@index([lastMessageAt])
  @@index([createdAt])
  @@map("chat_sessions")
}

model HandoffConsentEvidence {
  id              String    @id @default(uuid()) @db.Uuid
  sessionKey      String    @map("session_id")
  typebotResultId String?   @map("typebot_result_id")
  scope           String    @default("HANDOFF_CONTACT_COLLECTION")
  noticeVersion   String    @map("notice_version")
  accepted        Boolean
  acceptedAt      DateTime? @map("accepted_at")
  source          String    @default("typebot")
  locale          String    @default("ko")
  requestIpHash   String?   @map("request_ip_hash")
  requestUaHash   String?   @map("request_ua_hash")
  evidence        Json      @default("{}")
  retentionUntil  DateTime  @default(dbgenerated("now() + interval '90 days'")) @map("retention_until")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  session ChatSession @relation(fields: [sessionKey], references: [sessionKey], onDelete: Cascade)

  @@unique([sessionKey, scope, noticeVersion])
  @@index([typebotResultId])
  @@index([acceptedAt])
  @@index([retentionUntil])
  @@map("handoff_consent_evidence")
}

model ChatMessage {
  id                 BigInt   @id @default(autoincrement())
  sessionKey         String   @map("session_id")
  requestId          String   @unique @default(uuid()) @map("request_id") @db.Uuid
  idempotencyKey     String?  @unique @map("idempotency_key")
  tenantId           String   @default("default") @map("tenant_id")
  question           String
  questionCiphertext String?  @map("question_ciphertext")
  questionHash       String?  @map("question_hash")
  questionRedacted   Boolean  @default(false) @map("question_redacted")
  answer             String
  answerCiphertext   String?  @map("answer_ciphertext")
  answerHash         String?  @map("answer_hash")
  answerRedacted     Boolean  @default(false) @map("answer_redacted")
  riskLevel          String   @default("low") @map("risk_level")
  needsHuman         Boolean  @default(false) @map("needs_human")
  sourcesJson        String   @default("[]") @map("sources_json")
  source             String   @default("kaxi-site")
  channel            String   @default("kaxi-site")
  locale             String   @default("ko")
  executionId        String?  @map("execution_id")
  workflowId         String   @default("legacy-unversioned") @map("workflow_id")
  workflowVersionId  String   @default("legacy-unversioned") @map("workflow_version_id")
  modelVersion       String   @default("legacy-unversioned") @map("model_version")
  promptVersion      String   @default("legacy-unversioned") @map("prompt_version")
  status             String   @default("completed")
  errorCode          String?  @map("error_code")
  n8nRequest         Json?    @map("n8n_request")
  n8nResponse        Json?    @map("n8n_response")
  sources            Json?
  searchMeta         Json?    @map("search_meta")
  leadStage          String?  @map("lead_stage")
  nextStep           String?  @map("next_step")
  latencyMs          Int?     @map("latency_ms")
  createdAt          DateTime @default(now()) @map("created_at")

  attachments  ChatAttachment[]
  session      ChatSession      @relation(fields: [sessionKey], references: [sessionKey], onDelete: Cascade)
  retrievalRun RetrievalRun?
  auditMessage N8nAuditMessage?

  @@index([sessionKey])
  @@index([tenantId])
  @@index([source])
  @@index([locale])
  @@index([riskLevel])
  @@index([needsHuman])
  @@index([workflowId, workflowVersionId])
  @@index([createdAt])
  @@map("chat_messages")
}

model RetrievalRun {
  id                    String   @id @default(uuid()) @db.Uuid
  requestId             String   @unique @map("request_id") @db.Uuid
  messageId             BigInt   @unique @map("message_id")
  sessionKey            String   @map("session_id")
  executionId           String?  @map("execution_id")
  workflowId            String   @default("legacy-unversioned") @map("workflow_id")
  workflowVersionId     String   @default("legacy-unversioned") @map("workflow_version_id")
  modelVersion          String   @default("legacy-unversioned") @map("model_version")
  promptVersion         String   @default("legacy-unversioned") @map("prompt_version")
  query                 String
  queryCiphertext       String?  @map("query_ciphertext")
  queryHash             String?  @map("query_hash")
  queryRedacted         Boolean  @default(false) @map("query_redacted")
  retrievalType         String   @default("hybrid") @map("retrieval_type")
  category              String   @default("general")
  similarityThreshold   Float?   @map("similarity_threshold")
  topScore              Float?   @map("top_score")
  retrievedCount        Int      @default(0) @map("retrieved_count")
  rejectedCitationCount Int      @default(0) @map("rejected_citation_count")
  noContext             Boolean  @default(false) @map("no_context")
  noContextReason       String?  @map("no_context_reason")
  sources               Json     @default("[]")
  searchMeta            Json     @default("{}") @map("search_meta")
  createdAt             DateTime @default(now()) @map("created_at")

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  session ChatSession @relation(fields: [sessionKey], references: [sessionKey], onDelete: Cascade)

  @@index([sessionKey, createdAt])
  @@index([executionId])
  @@index([workflowId, workflowVersionId])
  @@index([noContext, createdAt])
  @@map("retrieval_runs")
}

model RagReviewFeedback {
  id                  String   @id @default(uuid()) @db.Uuid
  handoffTaskId       BigInt   @unique @map("handoff_task_id")
  sourceChatMessageId BigInt?  @map("source_chat_message_id")
  retrievalRunId      String?  @map("retrieval_run_id") @db.Uuid
  verdict             String
  reviewer            String
  expectedDocIds      Json     @default("[]") @map("expected_doc_ids")
  evaluationCaseId    String   @map("evaluation_case_id")
  metadata            Json     @default("{}")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([verdict, createdAt])
  @@index([evaluationCaseId])
  @@map("rag_review_feedback")
}

model ProductEvent {
  id          String   @id @default(uuid()) @db.Uuid
  eventId     String   @unique @map("event_id") @db.Uuid
  eventName   String   @map("event_name")
  anonymousId String   @map("anonymous_id") @db.Uuid
  sessionId   String?  @map("session_id")
  locale      String   @default("ko")
  surface     String
  path        String?
  properties  Json     @default("{}")
  occurredAt  DateTime @default(now()) @map("occurred_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([eventName, occurredAt])
  @@index([locale, occurredAt])
  @@index([anonymousId, occurredAt])
  @@index([sessionId, occurredAt])
  @@map("product_events")
}

model N8nAuditMessage {
  id                  BigInt   @id @default(autoincrement())
  executionId         String?  @unique @map("execution_id")
  workflowId          String   @default("legacy-unversioned") @map("workflow_id")
  workflowVersionId   String   @default("legacy-unversioned") @map("workflow_version_id")
  modelVersion        String   @default("legacy-unversioned") @map("model_version")
  promptVersion       String   @default("legacy-unversioned") @map("prompt_version")
  sourceChatMessageId BigInt?  @unique @map("source_chat_message_id")
  requestId           String?  @unique @map("request_id") @db.Uuid
  idempotencyKey      String?  @map("idempotency_key")
  sessionKey          String   @map("session_id")
  tenantId            String   @default("default") @map("tenant_id")
  locale              String   @default("ko")
  source              String   @default("typebot")
  channel             String   @default("typebot")
  question            String   @default("[canonical-chat-message]")
  questionHash        String?  @map("question_hash")
  questionRedacted    Boolean  @default(true) @map("question_redacted")
  answer              String   @default("[canonical-chat-message]")
  answerHash          String?  @map("answer_hash")
  answerRedacted      Boolean  @default(true) @map("answer_redacted")
  riskLevel           String   @default("low") @map("risk_level")
  needsHuman          Boolean  @default(false) @map("needs_human")
  leadStage           String?  @map("lead_stage")
  nextStep            String?  @map("next_step")
  sourcesJson         String   @default("[]") @map("sources_json")
  auditSource         String   @default("n8n-runtime") @map("audit_source")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  sourceChatMessage ChatMessage? @relation(fields: [sourceChatMessageId], references: [id], onDelete: SetNull)

  @@index([sessionKey, createdAt])
  @@index([tenantId, createdAt])
  @@index([channel])
  @@index([riskLevel, needsHuman])
  @@index([workflowId, workflowVersionId])
  @@map("n8n_audit_messages")
}

model ChatAttachment {
  id               String    @id @default(cuid())
  sessionKey       String    @map("session_id")
  messageId        BigInt?   @map("message_id")
  bucket           String
  storageKey       String    @unique @map("storage_key")
  originalName     String    @map("original_name")
  mimeType         String    @map("mime_type")
  sizeBytes        Int       @map("size_bytes")
  sha256           String
  status           String    @default("quarantined")
  detectedMimeType String?   @map("detected_mime_type")
  processingStatus String    @default("quarantined") @map("processing_status")
  processedAt      DateTime? @map("processed_at")
  retentionUntil   DateTime  @default(dbgenerated("now() + interval '30 days'")) @map("retention_until")
  deletedAt        DateTime? @map("deleted_at")
  metadata         Json?
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  session       ChatSession               @relation(fields: [sessionKey], references: [sessionKey], onDelete: Cascade)
  message       ChatMessage?              @relation(fields: [messageId], references: [id], onDelete: SetNull)
  extraction    ChatAttachmentExtraction?
  processingJob ChatAttachmentJob?

  @@index([sessionKey])
  @@index([messageId])
  @@index([sha256])
  @@index([mimeType])
  @@index([status])
  @@index([processingStatus, createdAt])
  @@index([retentionUntil])
  @@index([createdAt])
  @@map("chat_attachments")
}

model ChatAttachmentJob {
  id           String    @id @default(uuid()) @db.Uuid
  attachmentId String    @unique @map("attachment_id")
  status       String    @default("queued")
  attempts     Int       @default(0)
  maxAttempts  Int       @default(5) @map("max_attempts")
  availableAt  DateTime  @default(now()) @map("available_at")
  lockedAt     DateTime? @map("locked_at")
  lockToken    String?   @map("lock_token") @db.Uuid
  lastError    String?   @map("last_error")
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  attachment ChatAttachment @relation(fields: [attachmentId], references: [id], onDelete: Cascade)

  @@index([status, availableAt])
  @@index([lockedAt])
  @@map("chat_attachment_jobs")
}

model ChatAttachmentExtraction {
  attachmentId    String    @id @map("attachment_id")
  status          String    @default("pending")
  textCiphertext  String?   @map("text_ciphertext")
  textSha256      String?   @map("text_sha256")
  redactedPreview String?   @map("redacted_preview")
  documentType    String?   @map("document_type")
  language        String?
  confidence      Float?
  pageCount       Int?      @map("page_count")
  provider        String?
  model           String?
  errorCode       String?   @map("error_code")
  processedAt     DateTime? @map("processed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  attachment ChatAttachment @relation(fields: [attachmentId], references: [id], onDelete: Cascade)

  @@map("chat_attachment_extractions")
}

// AI Agent 요청 비용/품질 원장
model AgentRequestLedger {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  ip            String?
  userId        String?
  questionChars Int
  answerChars   Int     @default(0)

  backend       String
  codexMode     String?
  durationMs    Int?
  tokenEstimate Int

  success      Boolean
  errorType    String?
  errorMessage String?
  grounded     Boolean @default(false)
  toolCount    Int     @default(0)

  @@index([createdAt])
  @@index([ip])
  @@index([backend])
  @@index([success])
}

// 동의어 사전 (검색 품질 향상용)
// 일상어/방언/약어 → 공식 용어 매핑
// vector-store에서 쿼리 확장시 사용
model Synonym {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 원본 표현 (사용자가 실제로 입력하는 단어/구)
  // 예: "돈", "얼마", "비싸", "거절"
  source String @unique

  // 동의어/확장어 (공식 용어 리스트, JSON 배열)
  // 예: ["비용", "cost", "chi phí", "зардал"]
  targets String // JSON array

  // 카테고리 (관리 편의)
  category String @default("general") // cost, visa, documents, school, warning, general

  // 출처 — 자동 추출 or 관리자 수동 등록
  origin String @default("manual") // manual, auto, chatlog

  // 활성화 여부 (비활성시 검색에 사용 안 함)
  enabled Boolean @default(true)

  // 자동 추출 메타데이터
  autoMeta String? // JSON: { frequency, confidence, suggestedAt, chatLogIds }

  @@index([category])
  @@index([enabled])
  @@index([origin])
}

model RagQueryAlias {
  id         BigInt   @id @default(autoincrement())
  locale     String
  category   String   @default("general")
  term       String
  expansions String[]
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([locale, category, term])
  @@index([locale, category, enabled])
  @@map("rag_query_aliases")
}

// 관리자 및 개인정보 운영 감사 로그
model AdminAuditLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  actor      String
  actorRole  String  @default("admin")
  action     String
  targetType String
  targetId   String?
  ip         String?
  userAgent  String?
  success    Boolean @default(true)
  metadata   String?

  @@index([createdAt])
  @@index([actor])
  @@index([action])
  @@index([targetType])
}

// 다중 인스턴스 공유 rate limit 버킷
model RateLimitBucket {
  key       String   @id
  count     Int      @default(0)
  resetAt   DateTime
  updatedAt DateTime @updatedAt

  @@index([resetAt])
}

model ComplianceRule {
  id        String     @id @default(cuid())
  code      String     @unique
  domain    String
  visaType  String
  ruleType  String
  status    RuleStatus @default(DRAFT)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  versions ComplianceRuleVersion[]

  @@index([domain])
  @@index([visaType])
  @@index([ruleType])
  @@index([status])
}

model ComplianceRuleVersion {
  id             String            @id @default(cuid())
  ruleId         String
  version        Int
  effectiveFrom  DateTime
  effectiveTo    DateTime?
  conditionAst   Json
  outputAst      Json
  requiredInputs Json
  sourceRefs     Json
  fallbackPolicy String
  reviewStatus   LegalReviewStatus @default(PENDING)
  reviewedBy     String?
  reviewedAt     DateTime?
  createdAt      DateTime          @default(now())

  rule        ComplianceRule         @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  tests       ComplianceRuleTest[]
  evaluations ComplianceEvaluation[]

  @@unique([ruleId, version])
  @@index([effectiveFrom])
  @@index([effectiveTo])
  @@index([reviewStatus])
}

model ComplianceRuleTest {
  id            String   @id @default(cuid())
  ruleVersionId String
  caseId        String
  input         Json
  expected      Json
  lastResult    Json?
  passed        Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  ruleVersion ComplianceRuleVersion @relation(fields: [ruleVersionId], references: [id], onDelete: Cascade)

  @@unique([ruleVersionId, caseId])
  @@index([passed])
}

model ComplianceEvaluation {
  id               String    @id @default(cuid())
  studentProfileId String
  ruleVersionId    String
  inputSnapshot    Json
  outputSnapshot   Json
  riskLevel        RiskLevel @default(UNKNOWN)
  inputHash        String
  outputHash       String
  evaluatedAt      DateTime  @default(now())

  studentProfile StudentProfile        @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  ruleVersion    ComplianceRuleVersion @relation(fields: [ruleVersionId], references: [id], onDelete: Restrict)

  @@index([studentProfileId])
  @@index([ruleVersionId])
  @@index([riskLevel])
  @@index([evaluatedAt])
  @@index([inputHash])
  @@index([outputHash])
}

model KnowledgeDocument {
  id            String            @id @default(cuid())
  docId         String            @unique
  title         String
  sourceUrl     String
  sourceType    String
  language      String
  jurisdiction  String            @default("KR")
  topic         String
  validFrom     DateTime
  validTo       DateTime?
  lastCheckedAt DateTime
  checkedBy     String
  reviewStatus  LegalReviewStatus @default(PENDING)
  supersedes    Json?
  supersededBy  String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  chunks KnowledgeChunk[]

  @@index([sourceType])
  @@index([language])
  @@index([topic])
  @@index([validFrom])
  @@index([validTo])
  @@index([lastCheckedAt])
  @@index([reviewStatus])
  @@index([supersededBy])
}

model KnowledgeChunk {
  id             String                      @id @default(cuid())
  documentId     String
  chunkIndex     Int
  content        String
  contentHash    String
  keywords       String                      @default("")
  embeddingJson  Json?
  embedding      Unsupported("vector(384)")?
  tsv            Unsupported("tsvector")?
  embeddingModel String?
  embeddingDim   Int?
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt

  document KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, chunkIndex])
  @@index([contentHash])
  @@index([embeddingModel])
}

model EscalationCase {
  id                  String           @id @default(cuid())
  organizationId      String?
  studentProfileId    String
  assignedUserId      String?
  status              EscalationStatus @default(NEW)
  riskLevel           RiskLevel        @default(UNKNOWN)
  category            String
  summary             String
  conversationSummary String?
  ruleSnapshot        Json?
  aiDraft             String?
  matchedAt           DateTime?
  acceptedAt          DateTime?
  closedReason        String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  closedAt            DateTime?

  organization   Organization?       @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  studentProfile StudentProfile      @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  assignedUser   User?               @relation("AssignedCases", fields: [assignedUserId], references: [id], onDelete: SetNull)
  reviews        AgentReview[]
  timelineEvents CaseTimelineEvent[]
  documentLinks  CaseDocumentLink[]

  @@index([organizationId])
  @@index([studentProfileId])
  @@index([assignedUserId])
  @@index([status])
  @@index([riskLevel])
  @@index([category])
  @@index([matchedAt])
  @@index([acceptedAt])
  @@index([closedAt])
  @@index([createdAt])
}

model CaseTimelineEvent {
  id               String   @id @default(cuid())
  escalationCaseId String
  actorUserId      String?
  actorRole        String?
  eventType        String
  message          String?
  metadata         Json?
  createdAt        DateTime @default(now())

  escalationCase EscalationCase @relation(fields: [escalationCaseId], references: [id], onDelete: Cascade)
  actor          User?          @relation("CaseTimelineActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([escalationCaseId])
  @@index([actorUserId])
  @@index([eventType])
  @@index([createdAt])
}

model CaseDocumentLink {
  id               String   @id @default(cuid())
  escalationCaseId String
  documentItemId   String
  purpose          String   @default("shared")
  requested        Boolean  @default(false)
  note             String?
  createdAt        DateTime @default(now())

  escalationCase EscalationCase @relation(fields: [escalationCaseId], references: [id], onDelete: Cascade)
  documentItem   DocumentItem   @relation(fields: [documentItemId], references: [id], onDelete: Cascade)

  @@unique([escalationCaseId, documentItemId])
  @@index([escalationCaseId])
  @@index([documentItemId])
  @@index([requested])
  @@index([createdAt])
}

model AgentReview {
  id               String       @id @default(cuid())
  escalationCaseId String
  reviewerUserId   String?
  decision         ReviewStatus
  note             String?
  responseDraft    String?
  reviewedAt       DateTime     @default(now())
  createdAt        DateTime     @default(now())

  escalationCase EscalationCase @relation(fields: [escalationCaseId], references: [id], onDelete: Cascade)
  reviewer       User?          @relation("AgentReviewReviewer", fields: [reviewerUserId], references: [id], onDelete: SetNull)

  @@index([escalationCaseId])
  @@index([reviewerUserId])
  @@index([decision])
  @@index([reviewedAt])
}

model AuditEvent {
  id             String   @id @default(cuid())
  organizationId String?
  actorUserId    String?
  actorRole      String?
  action         String
  targetType     String
  targetId       String?
  caseId         String?
  ip             String?
  userAgent      String?
  success        Boolean  @default(true)
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  actor        User?         @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([actorUserId])
  @@index([action])
  @@index([targetType])
  @@index([targetId])
  @@index([caseId])
  @@index([createdAt])
}
