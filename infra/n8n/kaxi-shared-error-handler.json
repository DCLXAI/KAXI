{
  "name": "KAXI Shared Error Handler",
  "nodes": [
    {
      "id": "8705a470-99da-45b4-a27b-5fe0f602ceb1",
      "name": "Capture Workflow Failure",
      "type": "n8n-nodes-base.errorTrigger",
      "typeVersion": 1,
      "position": [
        0,
        0
      ],
      "parameters": {}
    },
    {
      "id": "5c01269c-5584-405e-8cae-34f64d758480",
      "name": "Persist Operational Failure",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        224,
        0
      ],
      "parameters": {
        "method": "POST",
        "url": "https://kaxi.vercel.app/api/internal/n8n/error-report",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "={{ 'Bearer ' + $env.KAXI_N8N_ERROR_TOKEN }}"
            }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "specifyBody": "json",
        "jsonBody": "={{ { eventType: 'workflow_execution_failed', severity: 'error', workflowId: $json.workflow?.id || 'n8n-unidentified-workflow', workflowName: $json.workflow?.name || '', workflowVersionId: $json.workflow?.versionId || 'n8n-runtime', executionId: $json.execution?.id || '', message: String($json.execution?.error?.message || $json.error?.message || 'n8n workflow failed').slice(0, 1000), lastNodeExecuted: $json.execution?.lastNodeExecuted || '', executionUrl: $json.execution?.url || '', mode: $json.execution?.mode || '' } }}",
        "options": {
          "response": {
            "response": {
              "neverError": true,
              "responseFormat": "json"
            }
          },
          "timeout": 10000
        }
      }
    }
  ],
  "connections": {
    "Capture Workflow Failure": {
      "main": [
        [
          {
            "node": "Persist Operational Failure",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "availableInMCP": true,
    "saveDataErrorExecution": "all",
    "saveDataSuccessExecution": "all",
    "timezone": "Asia/Seoul"
  },
  "active": false,
  "tags": []
}
