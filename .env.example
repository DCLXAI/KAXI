# Supabase/PostgreSQL database. Phase 0 makes this the only runtime DB target.
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"
# Destructive test suites only use this explicit, loopback-only database.
# The database name must end in `_test`; production/hosted hosts are rejected.
TEST_DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/kaxi_test"
POSTGRES_URL=""
PRISMA_DATABASE_URL=""
# Supabase Postgres aliases. Leave empty unless using Supabase as the operational database.
# Recommended:
# - DATABASE_URL or SUPABASE_POOLER_URL: pooled/session connection for app runtime.
# - SUPABASE_DIRECT_URL: direct DB connection for Prisma migrations.
SUPABASE_DATABASE_URL=""
SUPABASE_POOLER_URL=""
SUPABASE_DIRECT_URL=""
NEXT_PUBLIC_SUPABASE_URL=""
# Browser-safe anon key. This is intentionally exposed to client bundles.
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Server-only. Never expose, log, or return this value to browser/client code.
SUPABASE_SERVICE_ROLE_KEY=""
# Operator-only input for `bun run admin:bootstrap-supabase`; not an authorization source.
SUPABASE_ADMIN_EMAIL=""
SUPABASE_STORAGE_BUCKET="kaxi-documents"
# Optional separate private bucket for chat screenshot/file attachments.
# Falls back to SUPABASE_STORAGE_BUCKET when empty.
SUPABASE_CHAT_ATTACHMENTS_BUCKET=""
CHAT_SESSION_SIGNING_SECRET="replace-with-at-least-32-random-characters"
CHAT_SESSION_RATE_LIMIT=30
CHAT_ATTACHMENT_RATE_LIMIT=12
# structural: decode/re-encode images and reject active PDF content.
# http: additionally POST raw bytes to a managed scanner that returns { clean: true }.
ATTACHMENT_MALWARE_SCAN_MODE=structural
ATTACHMENT_MALWARE_SCAN_URL=""
ATTACHMENT_MALWARE_SCAN_TOKEN=""
ATTACHMENT_MALWARE_SCAN_TIMEOUT_MS=15000
# Set true to fail closed unless the managed scanner is configured.
ATTACHMENT_MALWARE_SCAN_REQUIRED=false
CHAT_ATTACHMENTS_ENABLED=false

# n8n webhooks are server-only and every request is HMAC-signed.
N8N_TYPEBOT_RAG_WEBHOOK_URL="https://your-workspace.app.n8n.cloud/webhook/typebot-rag-runtime"
N8N_RAG_WORKFLOW_ID="your-n8n-workflow-id"
N8N_RAG_WORKFLOW_VERSION_ID="kaxi-rag-runtime@2026-07-14.railway-mcp-v2"
N8N_RAG_MODEL_VERSION="retrieval/hybrid-rrf-v3@2026-07-14"
N8N_RAG_PROMPT_VERSION="kaxi-grounded-extractive@2026-07-13.p0-v1"
N8N_RAG_INGESTION_WEBHOOK_URL="https://your-workspace.app.n8n.cloud/webhook/rag-knowledge-ingest"
N8N_RAG_CAPABILITY_URL="https://your-workspace.app.n8n.cloud/webhook/rag-serving-capabilities"
N8N_TYPEBOT_HANDOFF_WEBHOOK_URL="https://your-workspace.app.n8n.cloud/webhook/typebot-handoff-update"
N8N_WEBHOOK_SIGNING_SECRET="replace-with-at-least-32-random-characters"
N8N_WEBHOOK_MAX_AGE_SECONDS=300
N8N_VERIFICATION_RECEIPT_TTL_SECONDS=60
N8N_VERIFY_RATE_LIMIT=240
N8N_RAG_CORE_RATE_LIMIT=240
N8N_RAG_INGESTION_RATE_LIMIT=120
N8N_HANDOFF_CORE_RATE_LIMIT=120
N8N_RAG_TIMEOUT_MS=35000
KAXI_DIRECT_RAG_TIMEOUT_MS=8000
# Keep the user-facing path inside one Vercel invocation. Set n8n only for rollback.
KAXI_RAG_RUNTIME_PRIMARY=direct
RAG_GROUNDED_ANSWER_TIMEOUT_MS=7500
# Zero-downtime embedding rollout. openai-primary automatically falls back to the
# retained 384d E5 index; e5-primary is the instant rollback switch.
KAXI_QUERY_EMBEDDINGS_ENABLED=true
KAXI_RAG_EMBEDDING_STRATEGY="openai-primary"
# Mark health degraded when the OpenAI probe fails while keeping the E5 user-path fallback alive.
KAXI_QUERY_EMBEDDING_REQUIRED=true
OPENAI_EMBEDDING_API_KEY=""
OPENAI_EMBEDDING_BASE_URL="https://api.openai.com/v1"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
OPENAI_EMBEDDING_TIMEOUT_MS=4000
TYPEBOT_HANDOFF_RATE_LIMIT=10
TYPEBOT_PUBLIC_ID="kaxi-rag-typebot"
TYPEBOT_PUBLIC_URL="https://typebot.co/kaxi-rag-typebot"
# Provider-side retention uses a dedicated account token and the editable bot ID.
TYPEBOT_API_BASE_URL="https://app.typebot.com"
TYPEBOT_BOT_ID="your-typebot-id"
TYPEBOT_API_TOKEN=""
TYPEBOT_RESULT_RETENTION_DAYS=7
# Server-only shared secret sent by both Typebot webhook blocks as x-kaxi-typebot-token.
TYPEBOT_GATEWAY_SECRET="replace-with-a-separate-32-byte-random-secret"
# Server-to-server and break-glass API access only. Never expose this in browser UI.
ADMIN_API_KEY="replace-with-a-long-random-secret"
ADMIN_API_KEY_PREVIOUS=""

# Keep PREVIOUS values only for a short overlap window, then remove them.
CHAT_SESSION_SIGNING_SECRET_PREVIOUS=""
N8N_WEBHOOK_SIGNING_SECRET_PREVIOUS=""
TYPEBOT_GATEWAY_SECRET_PREVIOUS=""
CRON_SECRET_PREVIOUS=""
SECURITY_CREDENTIALS_ROTATED_AT=""
SECURITY_CREDENTIAL_ROTATION_DAYS=90

# Privacy, retention, audit and scheduled enforcement
DATA_ENCRYPTION_KEY="replace-with-32-byte-base64-or-64-char-hex-secret"
PII_HASH_SECRET="replace-with-long-random-hmac-secret"
# Local development only. Production must not store unencrypted free-form text.
PII_ALLOW_UNENCRYPTED_PLAINTEXT=false
PRIVACY_CHATLOG_RETENTION_DAYS=90
PRIVACY_PARTNER_REQUEST_RETENTION_DAYS=180
PRIVACY_LEAD_RETENTION_DAYS=365
PRIVACY_CHAT_ATTACHMENT_RETENTION_DAYS=30
CRON_SECRET="replace-with-long-random-cron-secret"

# Real-time operations alerts. The legacy webhook supports JSON or Slack.
OPS_ALERT_WEBHOOK_URL=""
OPS_ALERT_FORMAT="json"
OPS_ALERT_SIGNING_SECRET=""
OPS_ALERT_SLACK_WEBHOOK_URL=""
RESEND_API_KEY=""
OPS_ALERT_EMAIL_FROM="KAXI Ops <ops@example.com>"
OPS_ALERT_EMAIL_TO=""
# When required, both Slack and email are expected unless channels are overridden.
OPS_ALERT_REQUIRED=false
OPS_ALERT_REQUIRED_CHANNELS="slack,email"

# Official source monitor alerts. Leave URL empty to disable notifications.
KNOWLEDGE_MONITOR_ALERT_WEBHOOK_URL=""
KNOWLEDGE_MONITOR_ALERT_FORMAT="json"
KNOWLEDGE_MONITOR_ALERT_SIGNING_SECRET=""
KNOWLEDGE_MONITOR_PERSIST_CANDIDATES=false
KNOWLEDGE_MONITOR_SOURCE_IDS=""
KNOWLEDGE_MONITOR_MAX_SOURCES=""
# Vercel daily cron checks a small critical set; the GitHub matrix covers the full watchlist.
KNOWLEDGE_MONITOR_CRON_SOURCE_IDS=""
KNOWLEDGE_MONITOR_FETCH_TIMEOUT_MS=8000
KNOWLEDGE_MONITOR_CONCURRENCY=2

# Shared limiter: auto uses database when writable; production finite limits fail closed without it.
RATE_LIMIT_BACKEND=auto

# Document upload workspace
DOCUMENT_UPLOAD_SIGNING_SECRET=""
DOCUMENT_UPLOAD_MAX_BYTES=10485760
DOCUMENT_UPLOAD_DIR="data/uploads"
DOCUMENT_UPLOAD_STORE_BYTES=true
# local | database | supabase | blob. Production default should be supabase private bucket.
DOCUMENT_UPLOAD_STORAGE_BACKEND="database"
BLOB_READ_WRITE_TOKEN=""
# Document verification RAG guardrail. Default 0.8 mirrors cosine distance <= 0.2.
DOCUMENT_RAG_MIN_VECTOR_SCORE=0.8
DOCUMENT_RAG_MIN_KEYWORD_SCORE=0

# AI abuse and cost controls
AI_CHAT_RATE_LIMIT=20
AI_CHAT_DAILY_QUOTA=100
AI_CHAT_MAX_CHARS=1200
AI_CONSULT_RATE_LIMIT=6
AI_CONSULT_DAILY_QUOTA=30
AI_CONSULT_MAX_CHARS=2500
AI_REQUIRE_LLM=false
AI_ALLOW_LLM_FALLBACK=true
AI_AGENT_RATE_LIMIT=6
AI_AGENT_DAILY_QUOTA=30
AI_AGENT_MAX_CHARS=2000
AI_AGENT_TIMEOUT_MS=45000
AI_AGENT_PREFLIGHT_ENABLED=true
AI_AGENT_PREFLIGHT_TIMEOUT_MS=12000
AI_AGENT_CONTEXT_MAX_CHARS=2400
AI_AGENT_GROUNDED_QUESTION_MAX_CHARS=3800
AI_AGENT_LOGGING_ENABLED=true
AI_AGENT_LEDGER_ENABLED=true
AI_AGENT_USE_TRANSFORMER_RAG=true
AI_CONSULT_USE_TRANSFORMER_RAG=true
AI_LLM_TIMEOUT_MS=25000
AI_EMBEDDING_INIT_TIMEOUT_MS=15000

# Managed AI backend. Kimi uses its OpenAI-compatible Chat Completions API.
# OPENAI_API_KEY may contain a Kimi key; KIMI_API_KEY and MOONSHOT_API_KEY are accepted aliases.
# Keep these server-only. Agent/consult can fall back unless AI_REQUIRE_LLM=true.
AI_PROVIDER="kimi"
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.moonshot.ai/v1"
OPENAI_MODEL="kimi-k2.6"
# Kimi Code keys instead require https://api.kimi.com/coding/v1 and kimi-for-coding.
# Kimi's documentation scopes that service to coding agents; public product integrations should use Kimi Platform.
# Optional Kimi override: enabled or disabled. Omit to use the model default.
KIMI_THINKING=""

# Optional Claude fallback. Select it explicitly with AI_PROVIDER="claude".
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-opus-4-8"

# Local model/vector cache paths
# Local default is ./data/model-cache. Vercel/serverless default is /tmp/kaxi-model-cache.
MODEL_CACHE_DIR="./data/model-cache"
VECTOR_CACHE_FILE="./data/vector-store/embeddings-cache.json"
RESTORE_MODEL_CACHE_ON_INSTALL=false
TRANSFORMERS_ALLOW_REMOTE=true
TRANSFORMERS_ALLOW_LOCAL=false
