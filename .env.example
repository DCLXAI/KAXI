# Supabase/PostgreSQL database. Phase 0 makes this the only runtime DB target.
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"
POSTGRES_URL=""
PRISMA_DATABASE_URL=""
# Supabase Postgres aliases. Leave empty unless using Supabase as the operational database.
# Recommended:
# - DATABASE_URL or SUPABASE_POOLER_URL: pooled/session connection for app runtime.
# - SUPABASE_DIRECT_URL: direct DB connection for Prisma migrations.
SUPABASE_DATABASE_URL=""
SUPABASE_POOLER_URL=""
SUPABASE_DIRECT_URL=""
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="kaxi-documents"
ADMIN_API_KEY="replace-with-a-long-random-secret"

# Admin web login. Required for /login and session-based admin access.
NEXTAUTH_SECRET="replace-with-a-long-random-nextauth-secret"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD_HASH="scrypt:replace-with-generated-salt:replace-with-generated-hash"
# Local/demo fallback only. Prefer ADMIN_PASSWORD_HASH in production.
ADMIN_PASSWORD=""
ADMIN_ROLE="owner"
# Required in hosted/production admin login.
ADMIN_MFA_TOTP_SECRET=""

# Privacy, retention, audit and scheduled enforcement
DATA_ENCRYPTION_KEY="replace-with-32-byte-base64-or-64-char-hex-secret"
PII_HASH_SECRET="replace-with-long-random-hmac-secret"
# Local development only. Production must not store unencrypted free-form text.
PII_ALLOW_UNENCRYPTED_PLAINTEXT=false
PRIVACY_CHATLOG_RETENTION_DAYS=90
PRIVACY_PARTNER_REQUEST_RETENTION_DAYS=180
PRIVACY_LEAD_RETENTION_DAYS=365
CRON_SECRET="replace-with-long-random-cron-secret"

# Official source monitor alerts. Leave URL empty to disable notifications.
KNOWLEDGE_MONITOR_ALERT_WEBHOOK_URL=""
KNOWLEDGE_MONITOR_ALERT_FORMAT="json"
KNOWLEDGE_MONITOR_ALERT_SIGNING_SECRET=""
KNOWLEDGE_MONITOR_PERSIST_CANDIDATES=true
KNOWLEDGE_MONITOR_SOURCE_IDS=""
KNOWLEDGE_MONITOR_MAX_SOURCES=""

# Shared limiter: auto uses database when writable; production finite limits fail closed without it.
RATE_LIMIT_BACKEND=auto

# Document upload workspace
DOCUMENT_UPLOAD_SIGNING_SECRET=""
DOCUMENT_UPLOAD_MAX_BYTES=10485760
DOCUMENT_UPLOAD_DIR="data/uploads"
DOCUMENT_UPLOAD_STORE_BYTES=true
DOCUMENT_UPLOAD_STORAGE_BACKEND="database"
BLOB_READ_WRITE_TOKEN=""

# AI abuse and cost controls
AI_CHAT_RATE_LIMIT=20
AI_CHAT_DAILY_QUOTA=100
AI_CHAT_MAX_CHARS=1200
AI_CONSULT_RATE_LIMIT=0
AI_CONSULT_DAILY_QUOTA=0
AI_CONSULT_MAX_CHARS=2500
AI_REQUIRE_LLM=false
AI_ALLOW_LLM_FALLBACK=true
AI_AGENT_RATE_LIMIT=0
AI_AGENT_DAILY_QUOTA=0
AI_AGENT_MAX_CHARS=2000
AI_AGENT_TIMEOUT_MS=45000
AI_AGENT_PREFLIGHT_ENABLED=true
AI_AGENT_PREFLIGHT_TIMEOUT_MS=12000
AI_AGENT_CONTEXT_MAX_CHARS=2400
AI_AGENT_GROUNDED_QUESTION_MAX_CHARS=3800
AI_AGENT_LOGGING_ENABLED=true
AI_AGENT_LEDGER_ENABLED=true
AI_LLM_TIMEOUT_MS=25000
AI_EMBEDDING_INIT_TIMEOUT_MS=15000

# Managed AI backend. Missing ANTHROPIC_API_KEY gracefully falls back to deterministic tools and official summaries unless AI_REQUIRE_LLM=true.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-opus-4-8"

# Local model/vector cache paths
# Local default is ./data/model-cache. Vercel/serverless default is /tmp/kaxi-model-cache.
MODEL_CACHE_DIR="./data/model-cache"
VECTOR_CACHE_FILE="./data/vector-store/embeddings-cache.json"
RESTORE_MODEL_CACHE_ON_INSTALL=false
TRANSFORMERS_ALLOW_REMOTE=true
TRANSFORMERS_ALLOW_LOCAL=false
