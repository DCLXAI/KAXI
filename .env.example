DATABASE_URL="file:./db/custom.db"
ADMIN_API_KEY="replace-with-a-long-random-secret"

# Admin web login. Required for /login and session-based admin access.
NEXTAUTH_SECRET="replace-with-a-long-random-nextauth-secret"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD_HASH="scrypt:replace-with-generated-salt:replace-with-generated-hash"
# Local/demo fallback only. Prefer ADMIN_PASSWORD_HASH in production.
ADMIN_PASSWORD=""
ADMIN_ROLE="owner"
ADMIN_MFA_TOTP_SECRET=""

# Privacy, retention, audit and scheduled enforcement
DATA_ENCRYPTION_KEY="replace-with-32-byte-base64-or-64-char-hex-secret"
PII_HASH_SECRET="replace-with-long-random-hmac-secret"
PRIVACY_CHATLOG_RETENTION_DAYS=90
PRIVACY_PARTNER_REQUEST_RETENTION_DAYS=180
PRIVACY_LEAD_RETENTION_DAYS=365
CRON_SECRET="replace-with-long-random-cron-secret"

# Shared limiter: auto uses database when writable, memory only for local/read-only demos.
RATE_LIMIT_BACKEND=auto

# AI abuse and cost controls
AI_CHAT_RATE_LIMIT=20
AI_CHAT_DAILY_QUOTA=100
AI_CHAT_MAX_CHARS=1200
AI_CONSULT_RATE_LIMIT=10
AI_CONSULT_DAILY_QUOTA=50
AI_CONSULT_MAX_CHARS=2500
AI_AGENT_RATE_LIMIT=0
AI_AGENT_DAILY_QUOTA=0
AI_AGENT_MAX_CHARS=2000
AI_AGENT_TIMEOUT_MS=45000
AI_AGENT_PREFLIGHT_ENABLED=true
AI_AGENT_PREFLIGHT_TIMEOUT_MS=12000
AI_AGENT_CONTEXT_MAX_CHARS=2400
AI_AGENT_GROUNDED_QUESTION_MAX_CHARS=3800
AI_AGENT_LOGGING_ENABLED=true
AI_AGENT_LEDGER_ENABLED=true
AI_LLM_TIMEOUT_MS=25000
AI_EMBEDDING_INIT_TIMEOUT_MS=15000

# AI agent backend. Defaults to Codex CLI; use "remote-bridge" for Mac tunnel proxy.
AGENT_BACKEND="codex"
CODEX_SERVERLESS_ENABLED=true
CODEX_AGENT_REQUIRE_ADMIN=false
# auto: local dev uses the current Codex CLI login; Vercel uses CODEX_API_KEY.
CODEX_AUTH_MODE=auto
CODEX_API_KEY=""
CODEX_MODEL=""
CODEX_CLI_PATH=""
CODEX_LOCAL_HOME=""
CODEX_USE_USER_CONFIG=false
CODEX_EXEC_TIMEOUT_MS=45000
CODEX_EXEC_RATE_LIMIT=3
CODEX_EXEC_MAX_CHARS=4000

# Optional browser-to-local Codex bridge for https://kaxi.vercel.app/agent.
NEXT_PUBLIC_CODEX_BRIDGE_URL=""
CODEX_BRIDGE_HOST="127.0.0.1"
CODEX_BRIDGE_PORT=8787
CODEX_BRIDGE_TOKEN=""
CODEX_BRIDGE_ALLOWED_ORIGINS="https://kaxi.vercel.app,https://kaxi-sunsus-projects.vercel.app,https://kaxi-git-main-sunsus-projects.vercel.app,http://localhost:3000,http://127.0.0.1:3000"
CODEX_BRIDGE_RATE_LIMIT=0
CODEX_BRIDGE_MAX_CHARS=4000
CODEX_REMOTE_BRIDGE_URL=""
CODEX_REMOTE_BRIDGE_TOKEN=""
CODEX_REMOTE_BRIDGE_TIMEOUT_MS=55000

# Optional legacy Z.ai SDK path. Leave disabled when using Codex CLI/bridge.
ZAI_ENABLED=false
ZAI_API_KEY=""
ZAI_CONFIG_PATH=""

# Local model/vector cache paths
MODEL_CACHE_DIR="./data/model-cache"
VECTOR_CACHE_FILE="./data/vector-store/embeddings-cache.json"
RESTORE_MODEL_CACHE_ON_INSTALL=false
TRANSFORMERS_ALLOW_REMOTE=true
TRANSFORMERS_ALLOW_LOCAL=false
